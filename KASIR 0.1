import React, { useState, useEffect } from 'react';
import { View, Text, TouchableOpacity, TextInput, StyleSheet, ScrollView, KeyboardAvoidingView, Platform, Keyboard, Modal, Alert, Switch, SafeAreaView, StatusBar } from 'react-native';
import * as Print from 'expo-print';
import * as Sharing from 'expo-sharing';
import AsyncStorage from '@react-native-async-storage/async-storage';

const STORAGE_KEY = '@nexuspay_data';
const HISTORY_KEY = '@nexuspay_history';
const CUSTOMER_KEY = '@nexuspay_customers';
const THEME_KEY = '@nexuspay_theme';

export default function App() {
  const [screen, setScreen] = useState('menu'); // menu atau kasir

  // ===== KODE KASIR LU YANG LAMA - TETEP UTUH =====
  const [isDarkMode, setIsDarkMode] = useState(false);
  const [namaToko, setNamaToko] = useState('NexusPay');
  const [alamatToko, setAlamatToko] = useState('Jl. Melati No. 5, Malang');
  const [telpToko, setTelpToko] = useState('0812-3456-7890');
  const [notesToko, setNotesToko] = useState('Terima kasih berbelanja di NexusPay');
  const [paymentMethods, setPaymentMethods] = useState('Cash / QRIS / Transfer');

  const [tab, setTab] = useState('kasir');
  const [produk, setProduk] = useState([
    {id: 1, nama: 'Aqua 600ml', harga: 3000},
    {id: 2, nama: 'Roti Tawar', harga: 12000},
    {id: 3, nama: 'Indomie Goreng', harga: 3500},
  ]);

  const [customers, setCustomers] = useState([]);
  const [customerTerpilih, setCustomerTerpilih] = useState(null);
  const [modalCustomer, setModalCustomer] = useState(false);
  const [modalPilihCustomer, setModalPilihCustomer] = useState(false);
  const [editCustomer, setEditCustomer] = useState({id: null, nama: '', telp: '', alamat: ''});

  const [keranjang, setKeranjang] = useState([]);
  const [nominalBayar, setNominalBayar] = useState('');
  const [isThermal, setIsThermal] = useState(false);
  const [riwayat, setRiwayat] = useState([]);
  const [modalProduk, setModalProduk] = useState(false);
  const [modalReview, setModalReview] = useState(false);
  const [htmlPreview, setHtmlPreview] = useState('');
  const [editProduk, setEditProduk] = useState({id: null, nama: '', harga: ''});
  const [keyboardHeight, setKeyboardHeight] = useState(0);

  useEffect(() => {
    loadData();
    loadHistory();
    loadCustomers();
    loadTheme();
  }, []);

  useEffect(() => { saveData(); }, [namaToko, alamatToko, telpToko, notesToko, paymentMethods, produk]);
  useEffect(() => { AsyncStorage.setItem(THEME_KEY, JSON.stringify(isDarkMode)); }, [isDarkMode]);
  useEffect(() => {
    const showSub = Keyboard.addListener('keyboardDidShow', (e) => setKeyboardHeight(e.endCoordinates.height));
    const hideSub = Keyboard.addListener('keyboardDidHide', () => setKeyboardHeight(0));
    return () => { showSub.remove(); hideSub.remove(); };
  }, []);

  const loadTheme = async () => {
    const json = await AsyncStorage.getItem(THEME_KEY);
    if (json) setIsDarkMode(JSON.parse(json));
  };

  const saveData = async () => {
    await AsyncStorage.setItem(STORAGE_KEY, JSON.stringify({namaToko, alamatToko, telpToko, notesToko, paymentMethods, produk}));
  };

  const loadData = async () => {
    const json = await AsyncStorage.getItem(STORAGE_KEY);
    if (json) {
      const data = JSON.parse(json);
      setNamaToko(data.namaToko || 'NexusPay');
      setAlamatToko(data.alamatToko || '');
      setTelpToko(data.telpToko || '');
      setNotesToko(data.notesToko || '');
      setPaymentMethods(data.paymentMethods || '');
      setProduk(data.produk || []);
    }
  };

  const saveCustomers = async (data) => {
    setCustomers(data);
    await AsyncStorage.setItem(CUSTOMER_KEY, JSON.stringify(data));
  };

  const loadCustomers = async () => {
    const json = await AsyncStorage.getItem(CUSTOMER_KEY);
    if (json) setCustomers(JSON.parse(json));
  };

  const simpanCustomer = () => {
    if (!editCustomer.nama) return Alert.alert('Error', 'Nama customer wajib diisi');
    if (editCustomer.id) {
      saveCustomers(customers.map(c => c.id === editCustomer.id? editCustomer : c));
    } else {
      saveCustomers([...customers, {...editCustomer, id: Date.now()}]);
    }
    setModalCustomer(false);
    setEditCustomer({id: null, nama: '', telp: '', alamat: ''});
  };

  const hapusCustomer = (id) => Alert.alert('Hapus', 'Yakin hapus customer ini?', [
    {text: 'Batal', style: 'cancel'},
    {text: 'Hapus', style: 'destructive', onPress: () => saveCustomers(customers.filter(c => c.id!== id))}
  ]);

  const saveHistory = async (invoice) => {
    const newHistory = [invoice,...riwayat].slice(0, 50);
    setRiwayat(newHistory);
    await AsyncStorage.setItem(HISTORY_KEY, JSON.stringify(newHistory));
  };

  const loadHistory = async () => {
    const json = await AsyncStorage.getItem(HISTORY_KEY);
    if (json) setRiwayat(JSON.parse(json));
  };

  const hapusRiwayat = async (id) => {
    Alert.alert('Hapus Riwayat', 'Yakin hapus transaksi ini?', [
      {text: 'Batal', style: 'cancel'},
      {text: 'Hapus', style: 'destructive', onPress: async () => {
        const newRiwayat = riwayat.filter(item => item.id!== id);
        setRiwayat(newRiwayat);
        await AsyncStorage.setItem(HISTORY_KEY, JSON.stringify(newRiwayat));
      }}
    ]);
  };

  const hapusSemuaRiwayat = () => {
    Alert.alert('Hapus Semua', 'Yakin hapus semua riwayat transaksi?', [
      {text: 'Batal', style: 'cancel'},
      {text: 'Hapus', style: 'destructive', onPress: async () => {
        setRiwayat([]);
        await AsyncStorage.removeItem(HISTORY_KEY);
      }}
    ]);
  };

  const formatRupiah = (angka) => {
    if (!angka && angka!== 0) return '';
    return angka.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
  };

  const handleBayarChange = (text) => setNominalBayar(text.replace(/\./g, ''));

  const tambahKeKeranjang = (item) => {
    setKeranjang(prev => {
      const ada = prev.find(p => p.id === item.id);
      if (ada) return prev.map(p => p.id === item.id? {...p, jumlah: p.jumlah + 1} : p);
      return [...prev, {...item, jumlah: 1}];
    });
  };

  const kurangJumlah = (id) => {
    setKeranjang(keranjang.map(item => {
      if (item.id === id) {
        const jumlahBaru = item.jumlah - 1;
        return jumlahBaru > 0? {...item, jumlah: jumlahBaru} : null;
      }
      return item;
    }).filter(Boolean));
  };

  const ubahJumlah = (id, text) => {
    const jumlah = parseInt(text) || 0;
    if (jumlah <= 0) setKeranjang(keranjang.filter(item => item.id!== id));
    else setKeranjang(keranjang.map(item => item.id === id? {...item, jumlah} : item));
  };

  const simpanProduk = () => {
    if (!editProduk.nama ||!editProduk.harga) return Alert.alert('Error', 'Nama & Harga wajib diisi');
    const hargaNum = parseInt(editProduk.harga.replace(/\./g, ''));
    if (editProduk.id) setProduk(produk.map(p => p.id === editProduk.id? {...p, nama: editProduk.nama, harga: hargaNum} : p));
    else setProduk([...produk, {id: Date.now(), nama: editProduk.nama, harga: hargaNum}]);
    setModalProduk(false);
    setEditProduk({id: null, nama: '', harga: ''});
  };

  const hapusProduk = (id) => Alert.alert('Hapus', 'Yakin?', [
    {text: 'Batal', style: 'cancel'},
    {text: 'Hapus', style: 'destructive', onPress: () => setProduk(produk.filter(p => p.id!== id))}
  ]);

  const total = keranjang.reduce((sum, item) => sum + item.harga * item.jumlah, 0);
  const kembalian = parseInt(nominalBayar) - total || 0;

  const theme = {
    bg: isDarkMode? '#121212' : '#F1F8E9',
    card: isDarkMode? '#1E1E1E' : 'white',
    text: isDarkMode? '#E0E0E0' : '#1B5E20',
    subtext: isDarkMode? '#B0B0B0' : '#666',
    border: isDarkMode? '#333' : '#4CAF50',
    header: '#2E7D32',
    input: isDarkMode? '#2A2A2A' : '#F1F8E9',
    tabBar: isDarkMode? '#1E1E1E' : 'white'
  };

  const buatHTML = () => {
    const tanggal = new Date().toLocaleString('id-ID');
    const noInvoice = 'INV-' + Date.now().toString().slice(-6);
    const customerInfo = customerTerpilih?
      `<p><b>Customer:</b> ${customerTerpilih.nama}<br><b>Telp:</b> ${customerTerpilih.telp || '-'}<br><b>Alamat:</b> ${customerTerpilih.alamat || '-'}</p>` : '';

    if (isThermal) {
      let struk = `<html><body style="font-family: monospace; font-size: 11px; width: 58mm; margin: 0; padding: 5px;">`;
      struk += `<div style="text-align: center;"><b>${namaToko}</b><br>${alamatToko}<br>Telp: ${telpToko}</div><hr>`;
      struk += `<div>No: ${noInvoice}<br>Tgl: ${tanggal}</div>`;
      if (customerTerpilih) struk += `<div>Customer: ${customerTerpilih.nama}</div>`;
      struk += `<hr>`;
      keranjang.forEach(item => {
        struk += `${item.nama}<br>${item.jumlah} x Rp${formatRupiah(item.harga)} = Rp${formatRupiah(item.harga * item.jumlah)}<br>`;
      });
      struk += `<hr>`;
      struk += `<b>TOTAL: Rp${formatRupiah(total)}</b><br>`;
      struk += `Bayar: Rp${formatRupiah(nominalBayar)}<br>`;
      struk += `Kembali: Rp${formatRupiah(kembalian > 0? kembalian : 0)}<hr>`;
      struk += `<div style="text-align: center;">${notesToko}</div>`;
      struk += `</body></html>`;
      return struk;
    } else {
      let barisBarang = '';
      keranjang.forEach((item, index) => {
        const subtotalItem = item.harga * item.jumlah;
        barisBarang += `<tr><td style="text-align: center; padding: 8px;">${index + 1}</td><td style="padding: 8px;">${item.nama}</td><td style="text-align: center; padding: 8px;">${item.jumlah}</td><td style="text-align: right; padding: 8px;">Rp${formatRupiah(item.harga)}</td><td style="text-align: right; padding: 8px;">Rp${formatRupiah(subtotalItem)}</td></tr>`;
      });

      return `
        <html><head><style>
          body { font-family: Arial; font-size: 12px; margin: 40px; color: #333; }
        .header { display: flex; justify-content: space-between; border-bottom: 3px solid #2E7D32; padding-bottom: 15px; margin-bottom: 25px; }
        .company h1 { margin: 0; font-size: 24px; color: #2E7D32; }
          table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
          th { background-color: #4CAF50; color: white; padding: 10px; text-align: left; font-size: 12px; }
          td { border: 1px solid #ddd; padding: 8px; font-size: 12px; }
        .totals { width: 300px; margin-left: auto; margin-top: 20px; }
        .grand-total { font-size: 18px; font-weight: bold; color: #2E7D32; border-top: 2px solid #2E7D32; background: #F1F8E9; }
        .customer-box { margin-bottom: 20px; padding: 12px; border: 1px solid #4CAF50; border-radius: 8px; background: #F1F8E9; }
        </style></head><body>
          <div class="header">
            <div class="company">
              <h1>${namaToko}</h1>
              <p>${alamatToko}</p>
              <p>Telp: ${telpToko}</p>
              <p><b>No Invoice:</b> ${noInvoice}<br><b>Tanggal:</b> ${tanggal}</p>
            </div>
            <div style="font-size: 32px; font-weight: bold; color: #2E7D32;">INVOICE</div>
          </div>
          ${customerInfo? `<div class="customer-box">${customerInfo}</div>` : ''}
          <table>
            <thead><tr><th style="width: 5%; text-align: center;">No</th><th style="width: 45%;">Description</th><th style="width: 10%; text-align: center;">Qty</th><th style="width: 20%; text-align: right;">Unit Price</th><th style="width: 20%; text-align: right;">Total</th></tr></thead>
            <tbody>${barisBarang}</tbody>
          </table>
          <table class="totals">
            <tr class="grand-total"><td>Total Amount</td><td style="text-align: right;">Rp${formatRupiah(total)}</td></tr>
          </table>
          <div style="margin-top: 30px; border-left: 3px solid #4CAF50; padding-left: 12px;">
            <h3 style="color: #2E7D32;">PAYMENT METHODS</h3>
            <p style="white-space: pre-line; font-size: 11px;">${paymentMethods}</p>
          </div>
        </body></html>
      `;
    }
  };

  const reviewInvoice = () => {
    if (keranjang.length === 0) return alert('Keranjang kosong!');
    if (!nominalBayar || parseInt(nominalBayar) < total) return alert('Uang kurang!');
    setHtmlPreview(buatHTML());
    setModalReview(true);
  };

  const cetakSekarang = async () => {
    try {
      const { uri } = await Print.printToFileAsync({
        html: htmlPreview,
        width: isThermal? 210 : 595,
        height: isThermal? 1000 : 842
      });

      const invoiceData = {
        id: Date.now(),
        noInvoice: 'INV-' + Date.now().toString().slice(-6),
        tanggal: new Date().toLocaleString('id-ID'),
        customer: customerTerpilih? customerTerpilih.nama : 'Umum',
        items: keranjang,
        total: total,
        bayar: parseInt(nominalBayar),
        kembali: kembalian,
        tipe: isThermal? 'Thermal' : 'A4'
      };
      saveHistory(invoiceData);

      await Sharing.shareAsync(uri, { mimeType: 'application/pdf', dialogTitle: 'Simpan Invoice' });
      setKeranjang([]);
      setNominalBayar('');
      setCustomerTerpilih(null);
      setModalReview(false);
    } catch (e) {
      alert('Gagal cetak: ' + e.message);
    }
  };

  // ===== HALAMAN MENU AWAL - IJO =====
  if(screen === 'menu') {
    return (
      <SafeAreaView style={styles.containerMenu}>
        <StatusBar backgroundColor="#2E7D32" barStyle="light-content" />

        <View style={styles.headerMenu}>
          <Text style={styles.judulMenu}>{namaToko}</Text>
          <Text style={styles.subMenu}>{alamatToko}</Text>
        </View>

        <View style={styles.gridMenu}>
          <TouchableOpacity
            style={styles.cardMenu}
            onPress={() => setScreen('kasir')}
          >
            <Text style={styles.cardTextMenu}>Transaksi / Kasir</Text>
          </TouchableOpacity>

          <TouchableOpacity
            style={styles.cardMenu}
            onPress={() => setScreen('kasir')}
          >
            <Text style={styles.cardTextMenu}>Setting</Text>
          </TouchableOpacity>

          <TouchableOpacity
            style={styles.cardMenu}
            onPress={() => setScreen('kasir')}
          >
            <Text style={styles.cardTextMenu}>Riwayat</Text>
          </TouchableOpacity>

          <TouchableOpacity
            style={styles.cardMenu}
            onPress={() => Alert.alert('Profil', 'Nama: ' + namaToko + '\nTelp: ' + telpToko)}
          >
            <Text style={styles.cardTextMenu}>Profil Toko</Text>
          </TouchableOpacity>
        </View>

        <Text style={styles.versionMenu}>Version 1.3</Text>
      </SafeAreaView>
    )
  }

  // ===== HALAMAN KASIR LU - GUE TAMBAHIN TOMBOL KEMBALI DOANG =====
  return (
    <View style={[styles.container, {backgroundColor: theme.bg}]}>
      <View style={styles.header}>
        <TouchableOpacity onPress={() => setScreen('menu')} style={{position: 'absolute', left: 20, top: 45}}>
          <Text style={{color: 'white', fontSize: 16, fontWeight: '600'}}>← Menu</Text>
        </TouchableOpacity>
        <Text style={styles.headerText}>{namaToko}</Text>
        <Text style={styles.headerSub}>{alamatToko}</Text>
      </View>

      <View style={{flex: 1}}>
        {tab === 'kasir'? (
          <>
            <TouchableOpacity style={[styles.btnPilihCustomer, {backgroundColor: theme.card, borderColor: theme.border}]} onPress={() => setModalPilihCustomer(true)}>
              <Text style={{fontWeight: '600', color: customerTerpilih? theme.header : theme.subtext}}>
                {customerTerpilih? `👤 ${customerTerpilih.nama}` : '👤 Pilih Customer'}
              </Text>
              {customerTerpilih && <Text style={{fontSize: 12, color: theme.subtext}}>{customerTerpilih.telp}</Text>}
            </TouchableOpacity>

            <ScrollView style={styles.productList} keyboardShouldPersistTaps="handled">
              {produk.map(item => {
                const itemDiKeranjang = keranjang.find(k => k.id === item.id);
                const jumlah = itemDiKeranjang? itemDiKeranjang.jumlah : 0;
                return (
                  <View key={item.id} style={[styles.productCard, {backgroundColor: theme.card, borderLeftColor: theme.border}]}>
                    <TouchableOpacity style={{flex: 1}} onPress={() => jumlah === 0 && tambahKeKeranjang(item)}>
                      <Text style={[styles.productName, {color: theme.text}]}>{item.nama}</Text>
                      <Text style={[styles.productPrice, {color: theme.header}]}>Rp{formatRupiah(item.harga)}</Text>
                    </TouchableOpacity>
                    {jumlah > 0 && (
                      <View style={styles.qtyControl}>
                        <TouchableOpacity style={[styles.qtyBtn, {backgroundColor: theme.header}]} onPress={() => kurangJumlah(item.id)}><Text style={styles.qtyBtnText}>-</Text></TouchableOpacity>
                        <TextInput style={[styles.qtyInput, {borderColor: theme.border, backgroundColor: theme.input, color: theme.text}]} value={jumlah.toString()} keyboardType="number-pad" onChangeText={(text) => ubahJumlah(item.id, text)}/>
                        <TouchableOpacity style={[styles.qtyBtn, {backgroundColor: theme.header}]} onPress={() => tambahKeKeranjang(item)}><Text style={styles.qtyBtnText}>+</Text></TouchableOpacity>
                      </View>
                    )}
                  </View>
                );
              })}
            </ScrollView>

            <KeyboardAvoidingView behavior={Platform.OS === 'ios'? 'padding' : 'height'}>
              <View style={[styles.paymentBox, {backgroundColor: theme.card, paddingBottom: keyboardHeight + 20, marginBottom: 60}]}>
                <View style={styles.totalRow}><Text style={[styles.totalLabel, {color: theme.subtext}]}>Total Bayar</Text><Text style={[styles.totalValue, {color: theme.text}]}>Rp{formatRupiah(total)}</Text></View>

                <View style={styles.inputRow}>
                  <Text style={[styles.rpLabel, {color: theme.header}]}>Rp</Text>
                  <TextInput style={[styles.inputBayar, {borderColor: theme.border, backgroundColor: theme.input, color: theme.text}]} placeholder="0" placeholderTextColor={theme.subtext} value={formatRupiah(nominalBayar)} onChangeText={handleBayarChange} keyboardType="number-pad" returnKeyType="done"/>
                </View>
                <View style={styles.totalRow}><Text style={[styles.changeLabel, {color: theme.subtext}]}>Kembalian</Text><Text style={styles.changeValue}>Rp{formatRupiah(kembalian > 0? kembalian : 0)}</Text></View>
                <TouchableOpacity style={[styles.btnBayar, {backgroundColor: theme.header}]} onPress={reviewInvoice}><Text style={styles.btnBayarText}>BAYAR & CETAK</Text></TouchableOpacity>

                <View style={{flexDirection: 'row', alignItems: 'center', justifyContent: 'center', marginTop: 15, paddingTop: 15, borderTopWidth: 1, borderTopColor: theme.border}}>
                  <Text style={{marginRight: 8, fontSize: 13, color: theme.subtext}}>Mode Struk 58mm</Text>
                  <Switch value={isThermal} onValueChange={setIsThermal} />
                </View>
              </View>
            </KeyboardAvoidingView>
          </>
        ) : tab === 'setting'? (
          <ScrollView style={styles.productList}>
            <View style={[styles.productCard, {backgroundColor: theme.card, justifyContent: 'space-between'}]}>
              <Text style={[styles.productName, {color: theme.text}]}>🌙 Dark Mode</Text>
              <Switch value={isDarkMode} onValueChange={setIsDarkMode} />
            </View>

            <Text style={[styles.sectionTitle, {color: theme.text}]}>Informasi Toko</Text>
            <TextInput style={[styles.settingInput, {backgroundColor: theme.card, borderColor: theme.border, color: theme.text}]} placeholder="Nama Toko" placeholderTextColor={theme.subtext} value={namaToko} onChangeText={setNamaToko}/>
            <TextInput style={[styles.settingInput, {backgroundColor: theme.card, borderColor: theme.border, color: theme.text}]} placeholder="Alamat Toko" placeholderTextColor={theme.subtext} value={alamatToko} onChangeText={setAlamatToko}/>
            <TextInput style={[styles.settingInput, {backgroundColor: theme.card, borderColor: theme.border, color: theme.text}]} placeholder="No Telepon" placeholderTextColor={theme.subtext} value={telpToko} onChangeText={setTelpToko} keyboardType="phone-pad"/>
            <TextInput style={[styles.settingInput, {backgroundColor: theme.card, borderColor: theme.border, color: theme.text, height: 80, textAlignVertical: 'top'}]} value={paymentMethods} onChangeText={setPaymentMethods} multiline placeholder="Payment Methods" placeholderTextColor={theme.subtext}/>
            <TextInput style={[styles.settingInput, {backgroundColor: theme.card, borderColor: theme.border, color: theme.text, height: 80, textAlignVertical: 'top'}]} value={notesToko} onChangeText={setNotesToko} multiline placeholder="Notes Invoice" placeholderTextColor={theme.subtext}/>

            <Text style={[styles.sectionTitle, {color: theme.text, marginTop: 20}]}>Manajemen Customer</Text>
            <TouchableOpacity style={[styles.btnTambahProduk, {backgroundColor: theme.header}]} onPress={() => {setEditCustomer({id: null, nama: '', telp: '', alamat: ''}); setModalCustomer(true)}}>
              <Text style={{color: 'white', fontWeight: 'bold', fontSize: 16}}>+ Tambah Customer</Text>
            </TouchableOpacity>
            {customers.length === 0? (
              <Text style={{textAlign: 'center', color: theme.subtext, marginTop: 20}}>Belum ada customer</Text>
            ) : customers.map(item => (
              <View key={item.id} style={[styles.productCard, {backgroundColor: theme.card, borderLeftColor: theme.border}]}>
                <View style={{flex: 1}}>
                  <Text style={[styles.productName, {color: theme.text}]}>{item.nama}</Text>
                  <Text style={{fontSize: 12, color: theme.subtext}}>{item.telp} - {item.alamat}</Text>
                </View>
                <TouchableOpacity onPress={() => {setEditCustomer(item); setModalCustomer(true)}} style={styles.btnEditSmall}>
                  <Text style={{fontSize: 13, fontWeight: '600'}}>Edit</Text>
                </TouchableOpacity>
                <TouchableOpacity onPress={() => hapusCustomer(item.id)} style={styles.btnHapus}>
                  <Text style={{color: 'white', fontSize: 13, fontWeight: 'bold'}}>X</Text>
                </TouchableOpacity>
              </View>
            ))}

            <Text style={[styles.sectionTitle, {color: theme.text, marginTop: 20}]}>Manajemen Produk</Text>
            <TouchableOpacity style={[styles.btnTambahProduk, {backgroundColor: theme.header}]} onPress={() => {setEditProduk({id: null, nama: '', harga: ''}); setModalProduk(true)}}>
              <Text style={{color: 'white', fontWeight: 'bold', fontSize: 16}}>+ Tambah Produk</Text>
            </TouchableOpacity>
            {produk.map(item => (
              <View key={item.id} style={[styles.productCard, {backgroundColor: theme.card, borderLeftColor: theme.border}]}>
                <View style={{flex: 1}}>
                  <Text style={[styles.productName, {color: theme.text}]}>{item.nama}</Text>
                  <Text style={[styles.productPrice, {color: theme.header}]}>Rp{formatRupiah(item.harga)}</Text>
                </View>
